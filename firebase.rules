// =====================================================================
// MOTALAB — REGRAS DE SEGURANÇA DO FIREBASE
// Cole cada bloco no Console do Firebase → aba "Rules"
// =====================================================================


// ─────────────────────────────────────────────────────────────────────
// FIRESTORE DATABASE RULES
// Console: https://console.firebase.google.com
// Projeto: mota-lab-e10e0
// Menu: Firestore Database → Rules
// ─────────────────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Administradores ───────────────────────────────────────────────
    // Usuários com role 'admin' no documento /admins/{uid} têm acesso
    // de leitura a todos os documentos de usuários.
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Usuários ──────────────────────────────────────────────────────
    // Cada usuário só pode ler e escrever o próprio documento.
    // Administradores podem ler (mas não escrever) qualquer documento.
    match /users/{userId} {
      allow read:  if request.auth != null
                   && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // ── Coleção de administradores ────────────────────────────────────
    // Somente leitura pelo próprio admin autenticado.
    // Escrita: bloqueada pelo client — faça via Console Firebase.
    match /admins/{adminId} {
      allow read:  if request.auth != null && request.auth.uid == adminId;
      allow write: if false; // Gerenciado apenas pelo Console Firebase
    }

    // ── Contador de cartões ──────────────────────────────────────────
    match /counters/{counterId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Reserva de códigos únicos de cartão
    match /codes/{codeId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── Bloqueio geral ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}


// ─────────────────────────────────────────────────────────────────────
// FIREBASE STORAGE RULES
// Console: https://console.firebase.google.com
// Projeto: mota-lab-e10e0
// Menu: Storage → Rules
// ─────────────────────────────────────────────────────────────────────

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Fotos dos titulares ───────────────────────────────────────────
    // Cada usuário pode:
    //   - Ler apenas a própria foto
    //   - Fazer upload apenas da própria foto
    //   - Tamanho máximo: 5MB
    //   - Tipo permitido: somente imagens
    match /photos/{userId} {
      allow read:  if request.auth != null
                   && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Bloqueio geral ────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}


// ─────────────────────────────────────────────────────────────────────
// ESTRUTURA DO FIRESTORE (referência)
// ─────────────────────────────────────────────────────────────────────
//
// /users/{uid}
//   uid          : string    (= Firebase Auth UID)
//   nome         : string
//   cpf          : string    (ex: "012.345.678-90")
//   nasc         : string    (ex: "1990-05-20")
//   email        : string
//   numCartao    : number    (ex: 1, 2, 3 ... sequencial)
//   dataAdesao   : string    (ex: "14/04/2026")
//   dataVenc     : string    (ex: "14/04/2027")
//   status       : string    ("ativo" | "inativo")
//   membros      : array
//     - nome       : string
//     - cpf        : string
//     - parentesco : string
//   fotoUrl      : string | null
//   createdAt    : Timestamp
//   updatedAt    : Timestamp
//
// /counters/global
//   proximoCartao : number   (inicializado automaticamente em 1)
//
// ─────────────────────────────────────────────────────────────────────
// AUTENTICAÇÃO
// Console: Authentication → Sign-in method
// Habilitar: "Email/Password"
// ─────────────────────────────────────────────────────────────────────


// ─────────────────────────────────────────────────────────────────────
// COMO CRIAR O USUÁRIO ADMINISTRADOR
// ─────────────────────────────────────────────────────────────────────
//
// PASSO 1 — Criar conta no Firebase Authentication:
//   Console → Authentication → Users → Add user
//   Informe: admin@motalab.com.br  +  sua senha
//   Copie o UID gerado (ex: "abc123xyz...")
//
// PASSO 2 — Criar documento na coleção /admins:
//   Console → Firestore Database → Start collection
//   Collection ID: admins
//   Document ID:   <cole o UID copiado acima>
//   Campo:  role  (string)  →  "admin"
//
// PASSO 3 — Atualizar ADMIN_CONFIG no motalab.js:
//   EMAIL: 'admin@motalab.com.br'   ← seu e-mail
//   SENHA: 'sua-senha-aqui'         ← sua senha
//
// PASSO 4 — Aplicar as regras do Firestore acima (que já incluem
//   a função isAdmin() verificando /admins/{uid}).
//
// ACESSO AO PAINEL:
//   No site, dê DUPLO-CLIQUE no logo MotaLab da barra superior.
//   O modal de login administrativo abrirá discretamente.
// ─────────────────────────────────────────────────────────────────────
